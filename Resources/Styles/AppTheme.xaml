<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <Color x:Key="AppBackgroundColor">#1c1c1c</Color>
    <Color x:Key="PrimaryColor">#2F4550</Color>
    <Color x:Key="SecondaryColor">#586F7C</Color>
    <Color x:Key="TextDarkColor">#F4F4F9</Color>
    <Color x:Key="TextLightColor">#B8DBD9</Color>
    <Color x:Key="BorderColor">#586F7C</Color>
    <Color x:Key="WhiteColor">#F4F4F9</Color>
    <Color x:Key="LoginColor">#0f4c5c</Color>
    <Color x:Key="SuccessColor">#66BB6A</Color>
    <Color x:Key="ErrorColor">#EF5350</Color>
    <Color x:Key="MutedSuccess">#4CAF50</Color>
    <Color x:Key="MutedError">#E57373</Color>
    <Color x:Key="MutedSuccess1">#8DAA91</Color>
    <Color x:Key="MutedError1">#B08B8B</Color>
    <Color x:Key="MutedSuccess2">#3E5C41</Color>
    <Color x:Key="MutedError2">#703E3E</Color>

    <Color x:Key="InputBackgroundColor">#2A2A2C</Color>
    

    <Style x:Key="HeaderLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="TextColor" Value="{StaticResource WhiteColor}" />
    </Style>

    <Style x:Key="SubHeaderLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Margin" Value="0,0,0,20" />
        <Setter Property="TextColor" Value="{StaticResource TextLightColor}" />
    </Style>

    <Style x:Key="NormalLabelStyle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource WhiteColor}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Margin" Value="0,15,0,0" />
    </Style>

    <Style x:Key="LinkLabelStyle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource LoginColor}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Margin" Value="0,15,0,0" />
    </Style>

    <Style x:Key="InputLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextLightColor}" />
        <Setter Property="Margin" Value="4,0,0,0" />
        <Setter Property="CharacterSpacing" Value="1.5" />
    </Style>

    <Style x:Key="InputContainerStyle" TargetType="Border">
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="16, 4" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
        <Setter Property="Margin" Value="0,0,0,5" />
    </Style>

    <Style x:Key="InputEntryStyle" TargetType="Entry">
        <Setter Property="Margin" Value="0, 4" />
        <Setter Property="TextColor" Value="{StaticResource WhiteColor}" />
        <Setter Property="PlaceholderColor" Value="#7A8B99" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="BackgroundColor" Value="{StaticResource LoginColor}" />
        <Setter Property="TextColor" Value="{StaticResource WhiteColor}" />
        <Setter Property="Padding" Value="0, 16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Margin" Value="0,20,0,0" />
    </Style>

    <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource SuccessColor}" />
    </Style>

    <Style x:Key="ErrorButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="BackgroundColor" Value="{StaticResource ErrorColor}" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="StrokeShape" Value="RoundRectangle 10" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="Padding" Value="24, 40" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="#1A1A1A" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource SecondaryColor}" Offset="0,4" Radius="8" Opacity="0.3" />
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="ProductCardStyle" TargetType="Border">
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="#1A1A1A" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource SecondaryColor}" Offset="0,2" Radius="6" Opacity="0.15" />
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="PillBorderStyle" TargetType="Border">
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="Padding" Value="16, 8" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
    </Style>

    <Style x:Key="PillLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextLightColor}" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>


    <FileImageSource x:Key="IconSearch" File="searchicon.png" />
    <FileImageSource x:Key="IconDashboard" File="dashboardicon.png" />
    <FileImageSource x:Key="IconLogout" File="logout.png" />
    <FileImageSource x:Key="IconCart" File="carticon.png" />
    <FileImageSource x:Key="Trash" File="trash.png"/>
    <FileImageSource x:Key="IconUsers" File="usericon.png" />
    <FileImageSource x:Key="IconProducts" File="product.png" />
    <FileImageSource x:Key="IconReports" File="reports.png" />
    <FileImageSource x:Key="IconHistory" File="historyicon.png" />

    <Style x:Key="CircularIconBorderStyle" TargetType="Border">
        <Setter Property="WidthRequest" Value="44" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="StrokeShape" Value="RoundRectangle 22" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
    </Style>







    <Style x:Key="StepperContainerStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <Style x:Key="StepperButtonBase" TargetType="Border">
        <Setter Property="HeightRequest" Value="36" />
        <Setter Property="WidthRequest" Value="55" />
        <Setter Property="StrokeShape" Value="RoundRectangle 8" />
    </Style>

    <Style x:Key="StepperMinusStyle" TargetType="Border" BasedOn="{StaticResource StepperButtonBase}">
        <Setter Property="BackgroundColor" Value="{StaticResource MutedError2}" />
    </Style>

    <Style x:Key="StepperPlusStyle" TargetType="Border" BasedOn="{StaticResource StepperButtonBase}">
        <Setter Property="BackgroundColor" Value="{StaticResource MutedSuccess2}" />
    </Style>

    <Style x:Key="StepperLabelStyle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource WhiteColor}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>



    <toolkit:InvertedBoolConverter x:Key="InverseBoolConverter" />


</ResourceDictionary>