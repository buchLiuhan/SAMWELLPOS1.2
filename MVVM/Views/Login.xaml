<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SAMWELLPOS.MVVM.ViewModels"
             x:Class="SAMWELLPOS.MVVM.Views.Login"
             x:DataType="viewmodels:LoginViewModel"
             BackgroundColor="{StaticResource AppBackgroundColor}">

    <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Padding="24" Spacing="40" HorizontalOptions="Fill" VerticalOptions="Center">

            <VerticalStackLayout HorizontalOptions="Center">
                <Image Source="samwelllogo.png" WidthRequest="160" Aspect="AspectFit" Margin="0,0,0,10" />
            </VerticalStackLayout>

            <Border Style="{StaticResource CardBorderStyle}" HorizontalOptions="Fill">
                <VerticalStackLayout Spacing="24">

                    <VerticalStackLayout Spacing="8">
                        <Label Text="USERNAME" Style="{StaticResource InputLabelStyle}" />
                        <Border Style="{StaticResource InputContainerStyle}">
                            <Entry Text="{Binding Username}"
                       Placeholder="e.g. john_doe"
                       Style="{StaticResource InputEntryStyle}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="PASSWORD" Style="{StaticResource InputLabelStyle}" />
                        <Border Style="{StaticResource InputContainerStyle}">
                            <Entry Text="{Binding Password}"
                       Placeholder="••••••••"
                       IsPassword="True"
                       Style="{StaticResource InputEntryStyle}" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Inline error — no more popups -->
                    <Border BackgroundColor="{StaticResource MutedError2}"
                StrokeShape="RoundRectangle 10"
                StrokeThickness="0"
                Padding="14,10"
                IsVisible="{Binding HasError}">
                        <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource WhiteColor}"
                   FontSize="13"
                   LineBreakMode="WordWrap" />
                    </Border>

                    <Button Text="Login"
                Command="{Binding LoginCommand}"
                Style="{StaticResource PrimaryButtonStyle}"
                Margin="0,15,0,0" />

                    <HorizontalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                               Margin="0,10,0,0" Spacing="5">
                        <Label Text="Don't have an account?"
                   TextColor="{StaticResource TextLightColor}"
                   VerticalOptions="Center" />
                        <Label Text="Register"
                   TextColor="{StaticResource LoginColor}"
                   FontAttributes="Bold"
                   TextDecorations="Underline"
                   VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>