<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SAMWELLPOS.MVVM.Views.User123.Dashboard.POSPayment"
             BackgroundColor="{StaticResource AppBackgroundColor}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *" Padding="24">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *" ColumnSpacing="16" Margin="0,0,0,24">
            <Border Grid.Column="0" Style="{StaticResource CircularIconBorderStyle}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Border.GestureRecognizers>
                <Label Text="←" FontSize="20"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       TextColor="{StaticResource WhiteColor}" />
            </Border>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                <Label Text="CASH PAYMENT" CharacterSpacing="1"
                       FontSize="11" TextColor="{StaticResource TextLightColor}" />
                <Label Text="Enter amount tendered"
                       FontAttributes="Bold" FontSize="16"
                       TextColor="{StaticResource WhiteColor}" />
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="20">

                <!-- Total Due -->
                <Border BackgroundColor="#1A1A1A"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        Padding="24,20">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="TOTAL AMOUNT DUE"
                               Style="{StaticResource InputLabelStyle}"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding TotalDisplay}"
                               FontSize="42" FontAttributes="Bold"
                               TextColor="{StaticResource LoginColor}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Cash Tendered -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="CASH TENDERED" Style="{StaticResource InputLabelStyle}" />
                    <Border Style="{StaticResource InputContainerStyle}" Padding="16,4">
                        <Grid ColumnDefinitions="Auto, *">
                            <Label Grid.Column="0" Text="₱"
                                   FontSize="18" FontAttributes="Bold"
                                   TextColor="{StaticResource TextLightColor}"
                                   VerticalOptions="Center"
                                   Margin="0,0,8,0" />
                            <Entry Grid.Column="1"
                                   Style="{StaticResource InputEntryStyle}"
                                   Keyboard="Numeric"
                                   Placeholder="0.00"
                                   FontSize="18" FontAttributes="Bold"
                                   Text="{Binding CashTendered}" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Quick Amount Buttons -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="QUICK AMOUNTS" Style="{StaticResource InputLabelStyle}" />
                    <Grid ColumnDefinitions="*, *, *, *" ColumnSpacing="8">

                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource InputBackgroundColor}"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0" Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetAmountCommand}"
                                                      CommandParameter="100" />
                            </Border.GestureRecognizers>
                            <Label Text="₱100" FontAttributes="Bold" FontSize="13"
                                   TextColor="{StaticResource WhiteColor}"
                                   HorizontalOptions="Center" />
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource InputBackgroundColor}"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0" Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetAmountCommand}"
                                                      CommandParameter="500" />
                            </Border.GestureRecognizers>
                            <Label Text="₱500" FontAttributes="Bold" FontSize="13"
                                   TextColor="{StaticResource WhiteColor}"
                                   HorizontalOptions="Center" />
                        </Border>

                        <Border Grid.Column="2"
                                BackgroundColor="{StaticResource InputBackgroundColor}"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0" Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetAmountCommand}"
                                                      CommandParameter="1000" />
                            </Border.GestureRecognizers>
                            <Label Text="₱1000" FontAttributes="Bold" FontSize="13"
                                   TextColor="{StaticResource WhiteColor}"
                                   HorizontalOptions="Center" />
                        </Border>

                        <Border Grid.Column="3"
                                BackgroundColor="{StaticResource LoginColor}"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0" Padding="0,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetExactAmountCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Exact" FontAttributes="Bold" FontSize="13"
                                   TextColor="{StaticResource WhiteColor}"
                                   HorizontalOptions="Center" />
                        </Border>

                    </Grid>
                </VerticalStackLayout>

                <!-- Change Display -->
                <Border StrokeShape="RoundRectangle 16"
        StrokeThickness="0"
        Padding="24,20"
        BackgroundColor="{StaticResource InputBackgroundColor}">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="CHANGE" Style="{StaticResource InputLabelStyle}"
               HorizontalOptions="Center" />

                        <!-- Shows green when enough cash -->
                        <Label Text="{Binding ChangeDisplay}"
               FontSize="36" FontAttributes="Bold"
               TextColor="{StaticResource SuccessColor}"
               HorizontalOptions="Center"
               IsVisible="{Binding IsInsufficient, Converter={StaticResource InverseBoolConverter}}" />

                        <!-- Shows red when insufficient -->
                        <Label Text="{Binding ChangeDisplay}"
               FontSize="36" FontAttributes="Bold"
               TextColor="{StaticResource ErrorColor}"
               HorizontalOptions="Center"
               IsVisible="{Binding IsInsufficient}" />

                    </VerticalStackLayout>
                </Border>

                <!-- Error Banner -->
                <Border BackgroundColor="{StaticResource MutedError2}"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        Padding="14,10"
                        IsVisible="{Binding HasError}">
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource WhiteColor}"
                           FontSize="13" LineBreakMode="WordWrap" />
                </Border>

                <!-- Confirm -->
                <Button Text="CONFIRM PAYMENT"
                        CharacterSpacing="1"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HeightRequest="56"
                        CornerRadius="12"
                        Margin="0,8,0,24"
                        Command="{Binding ConfirmPaymentCommand}" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>