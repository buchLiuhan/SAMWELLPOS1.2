<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SAMWELLPOS.MVVM.Views.User123.Dashboard.POSCart"
             BackgroundColor="{StaticResource AppBackgroundColor}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, Auto" Padding="16">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,16">
            <Border Grid.Column="0" Style="{StaticResource CircularIconBorderStyle}">
                <Label Text="←" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding BackCommand}"/>
                </Border.GestureRecognizers>
            </Border>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="CURRENT TRANSACTION" CharacterSpacing="1" FontSize="11" TextColor="{StaticResource TextLightColor}" HorizontalOptions="Center"/>
                <Label Text="Invoice #8821" FontAttributes="Bold" FontSize="16" TextColor="White" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <Border Grid.Column="2" Style="{StaticResource CircularIconBorderStyle}">
                <Image Source="{StaticResource Trash}" WidthRequest="20" HeightRequest="20" Opacity="0.8"/>
            </Border>
        </Grid>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="10">

                <Border Style="{StaticResource ProductCardStyle}" Padding="8">
                    <Grid ColumnDefinitions="60, *, Auto" ColumnSpacing="12">

                        <Border Grid.Column="0" HeightRequest="60" WidthRequest="60" StrokeShape="RoundRectangle 8" StrokeThickness="0">
                            <Image Source="samsungs23.png" Aspect="AspectFill" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Samsung S23" FontAttributes="Bold" FontSize="14" TextColor="White" LineBreakMode="NoWrap" />
                            <Label Text="$799.99" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource LoginColor}" />
                        </VerticalStackLayout>

                        <Border Grid.Column="2" Style="{StaticResource StepperContainerStyle}" VerticalOptions="Center" Padding="2">
                            <HorizontalStackLayout Spacing="6">
                                <Border Style="{StaticResource StepperMinusStyle}" WidthRequest="28" HeightRequest="28">
                                    <Label Text="-" Style="{StaticResource StepperLabelStyle}" FontSize="16" />
                                </Border>
                                <Label Text="1" WidthRequest="20" HorizontalTextAlignment="Center" Style="{StaticResource StepperLabelStyle}" FontSize="13" />
                                <Border Style="{StaticResource StepperPlusStyle}" WidthRequest="28" HeightRequest="28">
                                    <Label Text="+" Style="{StaticResource StepperLabelStyle}" FontSize="16" />
                                </Border>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource ProductCardStyle}" Padding="8">
                    <Grid ColumnDefinitions="60, *, Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" HeightRequest="60" WidthRequest="60" StrokeShape="RoundRectangle 8" StrokeThickness="0">
                            <Image Source="samsungs24.png" Aspect="AspectFill" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Samsung S24" FontAttributes="Bold" FontSize="14" TextColor="White" />
                            <Label Text="$1,000.00" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource LoginColor}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2" Style="{StaticResource StepperContainerStyle}" VerticalOptions="Center" Padding="2">
                            <HorizontalStackLayout Spacing="6">
                                <Border Style="{StaticResource StepperMinusStyle}" WidthRequest="28" HeightRequest="28">
                                    <Label Text="-" Style="{StaticResource StepperLabelStyle}" FontSize="16" />
                                </Border>
                                <Label Text="1" WidthRequest="20" HorizontalTextAlignment="Center" Style="{StaticResource StepperLabelStyle}" FontSize="13" />
                                <Border Style="{StaticResource StepperPlusStyle}" WidthRequest="28" HeightRequest="28">
                                    <Label Text="+" Style="{StaticResource StepperLabelStyle}" FontSize="16" />
                                </Border>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="2" Spacing="10" Padding="0,16,0,8">
            <BoxView HeightRequest="1" Color="#333" HorizontalOptions="Fill" />

            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                <Label Grid.Row="0" Text="Subtotal (2 items)" TextColor="{StaticResource TextLightColor}" FontSize="13"/>
                <Label Grid.Row="0" Grid.Column="1" Text="$1,799.99" TextColor="White" FontSize="13"/>

                <Label Grid.Row="1" Text="TOTAL TO PAY" FontAttributes="Bold" FontSize="14" TextColor="White" VerticalOptions="Center" Margin="0,10,0,0"/>
                <Label Grid.Row="1" Grid.Column="1" Text="$1,799.99" FontSize="26" FontAttributes="Bold" TextColor="{StaticResource LoginColor}" Margin="0,10,0,0"/>
            </Grid>

            <Button Text="COMPLETE PAYMENT" 
                    CharacterSpacing="1"
                    Style="{StaticResource PrimaryButtonStyle}" 
                    HeightRequest="56" 
                    CornerRadius="12"
                    Margin="0,8,0,0" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>