<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SAMWELLPOS.MVVM.Models"
             xmlns:vm="clr-namespace:SAMWELLPOS.MVVM.ViewModels"
             x:Class="SAMWELLPOS.MVVM.Views.User123.Dashboard.POSDashboard"
             BackgroundColor="{StaticResource AppBackgroundColor}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto" Padding="16,16,16,24">

        <ScrollView Grid.Row="0" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="16">

                <!-- Top Bar -->
                <Grid ColumnDefinitions="Auto, *, Auto, Auto" ColumnSpacing="10">

                    <!-- Cashier Avatar -->
                    <Grid Grid.Column="0" WidthRequest="44" HeightRequest="44">
                        <Border WidthRequest="44" HeightRequest="44"
                                StrokeShape="RoundRectangle 22" StrokeThickness="0"
                                BackgroundColor="{StaticResource LoginColor}"
                                IsVisible="{Binding CashierHasPhoto}">
                            <Image Source="{Binding CashierProfilePicturePath}"
                                   Aspect="AspectFill" WidthRequest="44" HeightRequest="44" />
                        </Border>
                        <Border WidthRequest="44" HeightRequest="44"
                                StrokeShape="RoundRectangle 22" StrokeThickness="0"
                                BackgroundColor="{StaticResource LoginColor}"
                                IsVisible="{Binding CashierHasPhoto, Converter={StaticResource InverseBoolConverter}}">
                            <Label Text="{Binding CashierInitials}"
                                   TextColor="{StaticResource WhiteColor}"
                                   FontSize="15" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <!-- Cart Badge -->
                    <Border Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center"
                            StrokeShape="RoundRectangle 20" StrokeThickness="0"
                            BackgroundColor="{StaticResource InputBackgroundColor}"
                            Padding="16,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToCartCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Image Source="{StaticResource IconCart}"
                                   WidthRequest="18" HeightRequest="18"
                                   VerticalOptions="Center" />
                            <Border StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource LoginColor}"
                                    Padding="8,2">
                                <Label Text="{Binding CartCount}"
                                       TextColor="{StaticResource WhiteColor}"
                                       FontSize="12" FontAttributes="Bold" />
                            </Border>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- History -->
                    <Border Grid.Column="2" Style="{StaticResource CircularIconBorderStyle}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToHistoryCommand}" />
                        </Border.GestureRecognizers>
                        <Image Source="{StaticResource IconHistory}"
                               WidthRequest="20" HeightRequest="20"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <!-- Logout -->
                    <Border Grid.Column="3" Style="{StaticResource CircularIconBorderStyle}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                        </Border.GestureRecognizers>
                        <Image Source="{StaticResource IconLogout}"
                               WidthRequest="20" HeightRequest="20"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                </Grid>

                <!-- Search -->
                <Border Style="{StaticResource InputContainerStyle}" Padding="16,4">
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                        <Entry Grid.Column="0"
                               Placeholder="Search products..."
                               Style="{StaticResource InputEntryStyle}"
                               Text="{Binding SearchText}" />
                        <Image Grid.Column="1" Source="{StaticResource IconSearch}"
                               WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Category Pills -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            Margin="-16,0">
                    <HorizontalStackLayout Spacing="12" Padding="16,0"
                                           BindableLayout.ItemsSource="{Binding Categories}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Style="{StaticResource PillBorderStyle}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SetCategoryCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding .}" Style="{StaticResource PillLabelStyle}" />
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Product Grid -->
                <CollectionView ItemsSource="{Binding FilteredProducts}"
                                VerticalScrollBarVisibility="Never"
                                Margin="0,0,0,80">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2"
                                         HorizontalItemSpacing="12" VerticalItemSpacing="12" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ProductModel">
                            <Border Style="{StaticResource ProductCardStyle}">
                                <VerticalStackLayout Spacing="8">

                                    <!-- Product Image -->
                                    <Grid>
                                        <Border HeightRequest="90"
                                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                                BackgroundColor="{StaticResource InputBackgroundColor}"
                                                IsVisible="{Binding HasImage}">
                                            <Image Source="{Binding ImagePath}" Aspect="AspectFill" />
                                        </Border>
                                        <Border HeightRequest="90"
                                                StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                                BackgroundColor="{StaticResource LoginColor}"
                                                IsVisible="{Binding HasImage, Converter={StaticResource InverseBoolConverter}}">
                                            <Label Text="{Binding Initials}"
                                                   FontSize="28" FontAttributes="Bold"
                                                   TextColor="{StaticResource WhiteColor}"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                    </Grid>

                                    <!-- Name -->
                                    <Label Text="{Binding Name}"
                                           FontAttributes="Bold" FontSize="13"
                                           TextColor="{StaticResource WhiteColor}"
                                           LineBreakMode="TailTruncation" MaxLines="1" />

                                    <!-- Price -->
                                    <Label Text="{Binding PriceDisplay}"
                                           FontAttributes="Bold" FontSize="13"
                                           TextColor="{StaticResource LoginColor}" />

                                    <!-- Stock -->
                                    <Label Text="{Binding StockDisplay}"
                                           FontSize="10" FontAttributes="Bold"
                                           TextColor="{Binding StockColor}" />


                                    <!-- Stepper with tap-to-type quantity -->
                                    <Border Style="{StaticResource StepperContainerStyle}" Padding="2">
                                        <Grid ColumnDefinitions="36, *, 36">

                                            <Border Grid.Column="0"
                BackgroundColor="{StaticResource MutedError2}"
                HeightRequest="32" StrokeShape="RoundRectangle 6">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                    Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.DecrementCommand}"
                    CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="−" FontSize="16" FontAttributes="Bold"
                   TextColor="{StaticResource WhiteColor}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>

                                            <!-- Tappable quantity label -->
                                            <Border Grid.Column="1"
                BackgroundColor="Transparent"
                StrokeThickness="0">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                    Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.PromptQuantityCommand}"
                    CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="{Binding CartQuantityDisplay}"
                   FontSize="12" FontAttributes="Bold"
                   TextColor="{StaticResource WhiteColor}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>

                                            <Border Grid.Column="2"
                BackgroundColor="{StaticResource MutedSuccess2}"
                HeightRequest="32" StrokeShape="RoundRectangle 6">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                    Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.IncrementCommand}"
                    CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="+" FontSize="16" FontAttributes="Bold"
                   TextColor="{StaticResource WhiteColor}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>

                                        </Grid>
                                    </Border>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Bar -->
        <Grid Grid.Row="1">
            <Border StrokeShape="RoundRectangle 30" StrokeThickness="0"
                    BackgroundColor="#0A0A0A" Padding="8">
                <Button Text="CHARGE"
                        BackgroundColor="{StaticResource LoginColor}"
                        TextColor="{StaticResource WhiteColor}"
                        CornerRadius="24" FontAttributes="Bold" FontSize="16"
                        HeightRequest="52" CharacterSpacing="1"
                        Command="{Binding GoToCartCommand}" />
            </Border>
        </Grid>

    </Grid>
</ContentPage>