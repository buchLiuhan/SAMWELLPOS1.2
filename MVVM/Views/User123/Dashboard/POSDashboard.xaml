<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SAMWELLPOS.MVVM.Models"
             xmlns:vm="clr-namespace:SAMWELLPOS.MVVM.ViewModels"
             x:Class="SAMWELLPOS.MVVM.Views.User123.Dashboard.POSDashboard"
             BackgroundColor="{StaticResource AppBackgroundColor}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto" Padding="16,16,16,24">

        <ScrollView Grid.Row="0" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="20">

                <!-- Top Bar -->
                <Grid ColumnDefinitions="Auto, *, Auto">

                    <!-- Dashboard icon -->
                    <Border Grid.Column="0" Style="{StaticResource CircularIconBorderStyle}">
                        <Image Source="{StaticResource IconDashboard}"
                               WidthRequest="20" HeightRequest="20"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <!-- Cart button with badge -->
                    <Border Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center"
                            StrokeShape="RoundRectangle 20" StrokeThickness="0"
                            BackgroundColor="{StaticResource InputBackgroundColor}"
                            Padding="16,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToCartCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Image Source="{StaticResource IconCart}"
                                   WidthRequest="18" HeightRequest="18"
                                   VerticalOptions="Center" />
                            <Border StrokeShape="RoundRectangle 12"
                                    BackgroundColor="{StaticResource LoginColor}"
                                    Padding="8,2">
                                <Label Text="{Binding CartCount}"
                                       TextColor="{StaticResource WhiteColor}"
                                       FontSize="12" FontAttributes="Bold" />
                            </Border>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Logout -->
                    <Border Grid.Column="2" Style="{StaticResource CircularIconBorderStyle}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                        </Border.GestureRecognizers>
                        <Image Source="{StaticResource IconLogout}"
                               WidthRequest="20" HeightRequest="20"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                </Grid>

                <!-- Search -->
                <Border Style="{StaticResource InputContainerStyle}" Padding="16,4">
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                        <Entry Grid.Column="0"
                               Placeholder="Search products..."
                               Style="{StaticResource InputEntryStyle}"
                               Text="{Binding SearchText}" />
                        <Image Grid.Column="1"
                               Source="{StaticResource IconSearch}"
                               WidthRequest="22" HeightRequest="22"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Category Pills -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            Margin="-16,0">
                    <BindableLayout.ItemsSource>
                        <Binding Path="Categories" />
                    </BindableLayout.ItemsSource>
                    <HorizontalStackLayout x:Name="CategoryPills"
                                           Spacing="12" Padding="16,0"
                                           BindableLayout.ItemsSource="{Binding Categories}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Style="{StaticResource PillBorderStyle}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SetCategoryCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding .}"
                                           Style="{StaticResource PillLabelStyle}" />
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Product Grid -->
                <CollectionView ItemsSource="{Binding FilteredProducts}"
                                VerticalScrollBarVisibility="Never"
                                Margin="0,0,0,80">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="2"
                                         HorizontalItemSpacing="12"
                                         VerticalItemSpacing="16" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ProductModel">
                            <Border Style="{StaticResource ProductCardStyle}">
                                <VerticalStackLayout Spacing="12">

                                    <!-- Product Image -->
                                    <Grid>
                                        <Border HeightRequest="110"
                                                StrokeShape="RoundRectangle 12"
                                                StrokeThickness="0"
                                                BackgroundColor="{StaticResource InputBackgroundColor}"
                                                IsVisible="{Binding HasImage}">
                                            <Image Source="{Binding ImagePath}"
                                                   Aspect="AspectFill" />
                                        </Border>

                                        <Border HeightRequest="110"
                                                StrokeShape="RoundRectangle 12"
                                                StrokeThickness="0"
                                                BackgroundColor="{StaticResource LoginColor}"
                                                IsVisible="{Binding HasImage, Converter={StaticResource InverseBoolConverter}}">
                                            <Label Text="{Binding Initials}"
                                                   FontSize="36" FontAttributes="Bold"
                                                   TextColor="{StaticResource WhiteColor}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Border>
                                    </Grid>

                                    <VerticalStackLayout Spacing="8">

                                        <!-- Name + Price -->
                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold" FontSize="14"
                                               TextColor="{StaticResource WhiteColor}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />
                                        <Label Text="{Binding PriceDisplay}"
                                               FontAttributes="Bold" FontSize="14"
                                               TextColor="{StaticResource LoginColor}" />

                                        <!-- Stepper -->
                                        <Border Style="{StaticResource StepperContainerStyle}">
                                            <Grid ColumnDefinitions="55, *, 55">

                                                <Border Grid.Column="0"
                                                        BackgroundColor="{StaticResource MutedError2}"
                                                        HeightRequest="36"
                                                        StrokeShape="RoundRectangle 8">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.DecrementCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Border.GestureRecognizers>
                                                    <Label Text="-"
                                                           Style="{StaticResource StepperLabelStyle}"
                                                           FontSize="20" />
                                                </Border>

                                                <Label Grid.Column="1"
                                                       Text="{Binding CartQuantityDisplay}"
                                                       Style="{StaticResource StepperLabelStyle}" />

                                                <Border Grid.Column="2"
                                                        BackgroundColor="{StaticResource MutedSuccess2}"
                                                        HeightRequest="36"
                                                        StrokeShape="RoundRectangle 8">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.IncrementCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Border.GestureRecognizers>
                                                    <Label Text="+"
                                                           Style="{StaticResource StepperLabelStyle}"
                                                           FontSize="20" />
                                                </Border>

                                            </Grid>
                                        </Border>

                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Bar -->
        <Grid Grid.Row="1">
            <Border StrokeShape="RoundRectangle 30"
                    StrokeThickness="0"
                    BackgroundColor="#0A0A0A"
                    Padding="8">
                <Grid ColumnDefinitions="*, *">
                    <Button Grid.Column="0"
                            Text="View Cart"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource WhiteColor}"
                            FontAttributes="Bold" FontSize="16"
                            HeightRequest="48"
                            Command="{Binding GoToCartCommand}" />
                    <Button Grid.Column="1"
                            Text="Charge"
                            BackgroundColor="{StaticResource LoginColor}"
                            TextColor="{StaticResource WhiteColor}"
                            CornerRadius="24"
                            FontAttributes="Bold" FontSize="16"
                            HeightRequest="48"
                            Command="{Binding GoToCartCommand}" />
                </Grid>
            </Border>
        </Grid>

    </Grid>
</ContentPage>