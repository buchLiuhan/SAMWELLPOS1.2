<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SAMWELLPOS.MVVM.Models"
             x:Class="SAMWELLPOS.MVVM.Views.User123.Dashboard.POSReceipt"
             BackgroundColor="{StaticResource AppBackgroundColor}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, Auto" Padding="24">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center"
                             Margin="0,0,0,20" Spacing="4">
            <Image Source="samwelllogo.png" WidthRequest="120"
                   Aspect="AspectFit" HorizontalOptions="Center" />
            <Label Text="OFFICIAL RECEIPT"
                   CharacterSpacing="2" FontSize="11" FontAttributes="Bold"
                   TextColor="{StaticResource TextLightColor}"
                   HorizontalOptions="Center" />
            <Label Text="{Binding TransactionNumber}"
                   FontSize="13" FontAttributes="Bold"
                   TextColor="{StaticResource WhiteColor}"
                   HorizontalOptions="Center" />
            <Label Text="{Binding TransactionDate}"
                   FontSize="12"
                   TextColor="{StaticResource TextLightColor}"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Receipt Body -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="16">

                <!-- Items Card -->
                <Border BackgroundColor="#1A1A1A"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        Padding="20">
                    <VerticalStackLayout Spacing="0">

                        <!-- Column headers -->
                        <Grid ColumnDefinitions="*, Auto, Auto" Margin="0,0,0,8">
                            <Label Grid.Column="0" Text="ITEM"
                                   Style="{StaticResource InputLabelStyle}" />
                            <Label Grid.Column="1" Text="QTY"
                                   Style="{StaticResource InputLabelStyle}"
                                   Margin="0,0,20,0" />
                            <Label Grid.Column="2" Text="AMOUNT"
                                   Style="{StaticResource InputLabelStyle}" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="#2A2A2C" Margin="0,0,0,12" />

                        <!-- Items -->
                        <CollectionView ItemsSource="{Binding ReceiptItems}"
                                        VerticalScrollBarVisibility="Never">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:CartItem">
                                    <Grid ColumnDefinitions="*, Auto, Auto"
                                          Margin="0,0,0,10">
                                        <VerticalStackLayout Grid.Column="0" Spacing="1">
                                            <Label Text="{Binding Product.Name}"
                                                   FontAttributes="Bold" FontSize="13"
                                                   TextColor="{StaticResource WhiteColor}"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1" />
                                            <Label Text="{Binding Product.PriceDisplay}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TextLightColor}" />
                                        </VerticalStackLayout>

                                        <Label Grid.Column="1"
                                               Text="{Binding Quantity}"
                                               FontSize="13"
                                               TextColor="{StaticResource TextLightColor}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               Margin="0,0,20,0" />

                                        <Label Grid.Column="2"
                                               FontSize="13" FontAttributes="Bold"
                                               TextColor="{StaticResource WhiteColor}"
                                               VerticalOptions="Center">
                                            <Label.Text>
                                                <MultiBinding StringFormat="₱{0:N2}">
                                                    <Binding Path="LineTotal" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <BoxView HeightRequest="1" Color="#2A2A2C" Margin="0,8,0,12" />

                        <!-- Totals -->
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto"
                              RowSpacing="8">

                            <Label Grid.Row="0"
                                   Text="{Binding ItemCountDisplay}"
                                   TextColor="{StaticResource TextLightColor}"
                                   FontSize="13" />
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding TotalDisplay}"
                                   TextColor="{StaticResource WhiteColor}"
                                   FontSize="13" />

                            <Label Grid.Row="1"
                                   Text="Cash Tendered"
                                   TextColor="{StaticResource TextLightColor}"
                                   FontSize="13" />
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding CashTenderedDisplay}"
                                   TextColor="{StaticResource WhiteColor}"
                                   FontSize="13" />

                            <BoxView Grid.Row="2" Grid.ColumnSpan="2"
                                     HeightRequest="1" Color="#2A2A2C" />
                        </Grid>

                        <!-- Change -->
                        <Grid ColumnDefinitions="*, Auto" Margin="0,12,0,0">
                            <Label Text="CHANGE"
                                   FontAttributes="Bold" FontSize="15"
                                   TextColor="{StaticResource WhiteColor}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding ChangeDisplay}"
                                   FontSize="28" FontAttributes="Bold"
                                   TextColor="{StaticResource SuccessColor}" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Thank you -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                    <Label Text="Thank you for your purchase!"
                           FontAttributes="Bold" FontSize="15"
                           TextColor="{StaticResource WhiteColor}"
                           HorizontalOptions="Center" />
                    <Label Text="Please come again."
                           FontSize="13"
                           TextColor="{StaticResource TextLightColor}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- New Transaction -->
        <Button Grid.Row="2"
                Text="NEW TRANSACTION"
                CharacterSpacing="1"
                Style="{StaticResource PrimaryButtonStyle}"
                HeightRequest="56"
                CornerRadius="12"
                Margin="0,16,0,0"
                Command="{Binding NewTransactionCommand}" />

    </Grid>
</ContentPage>