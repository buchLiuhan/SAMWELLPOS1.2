<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SAMWELLPOS.MVVM.ViewModels"
             xmlns:models="clr-namespace:SAMWELLPOS.MVVM.Models"
             x:Class="SAMWELLPOS.MVVM.Views.Admin.User_Management"
             Title="User Management"
             BackgroundColor="{StaticResource AppBackgroundColor}">

    <Grid RowDefinitions="Auto, Auto, *" Padding="16, 24, 16, 0">

        <!-- Logo + Logout -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <VerticalStackLayout HorizontalOptions="Center">
                <Image Source="samwelllogo.png" WidthRequest="160" Aspect="AspectFit" />
            </VerticalStackLayout>
            <Border Style="{StaticResource CircularIconBorderStyle}"
                    HorizontalOptions="End" VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                </Border.GestureRecognizers>
                <Image Source="{StaticResource IconLogout}"
                       WidthRequest="22" HeightRequest="22"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>

        <!-- Search + Add -->
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto" ColumnSpacing="12" Margin="0,0,0,20">
            <Border Grid.Column="0" Style="{StaticResource InputContainerStyle}" Padding="16, 4" Margin="0">
                <Grid ColumnDefinitions="*, Auto">
                    <Entry Grid.Column="0"
                           Placeholder="Search users..."
                           Style="{StaticResource InputEntryStyle}"
                           Text="{Binding SearchText}" />
                    <Image Grid.Column="1"
                           Source="{StaticResource IconSearch}"
                           WidthRequest="22" HeightRequest="22"
                           VerticalOptions="Center" />
                </Grid>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource PillBorderStyle}"
                    BackgroundColor="{StaticResource LoginColor}" Padding="16, 0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateToCreateCommand}" />
                </Border.GestureRecognizers>
                <Label Text="+ Add" Style="{StaticResource PillLabelStyle}"
                       TextColor="{StaticResource WhiteColor}" />
            </Border>
        </Grid>

        <!-- User Cards -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding FilteredUsers}"
                        VerticalScrollBarVisibility="Never">

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="2"
                                 HorizontalItemSpacing="12"
                                 VerticalItemSpacing="12" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:UserModel">
                    <Grid VerticalOptions="Start" Margin="0,0,0,0">

                        <!-- Normal card — everyone except current user -->
                        <Border Style="{StaticResource ProductCardStyle}"
                                IsVisible="{Binding IsCurrentUser, Converter={StaticResource InverseBoolConverter}}">
                            <VerticalStackLayout Spacing="12" HorizontalOptions="Center" Padding="0,8">

                                <Grid WidthRequest="54" HeightRequest="54" HorizontalOptions="Center">
                                    <Border WidthRequest="50" HeightRequest="50"
                                            StrokeShape="RoundRectangle 25" StrokeThickness="0"
                                            BackgroundColor="{Binding AvatarColor}"
                                            IsVisible="{Binding HasProfilePicture}">
                                        <Image Source="{Binding ProfilePicturePath}"
                                               Aspect="AspectFill"
                                               WidthRequest="50" HeightRequest="50" />
                                    </Border>
                                    <Border WidthRequest="50" HeightRequest="50"
                                            StrokeShape="RoundRectangle 25" StrokeThickness="0"
                                            BackgroundColor="{Binding AvatarColor}"
                                            IsVisible="{Binding HasProfilePicture, Converter={StaticResource InverseBoolConverter}}">
                                        <Label Text="{Binding Initials}"
                                               TextColor="{StaticResource WhiteColor}"
                                               FontSize="18" FontAttributes="Bold"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                </Grid>

                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding FullName}"
                                           FontAttributes="Bold" FontSize="14"
                                           TextColor="{StaticResource WhiteColor}"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding Role}"
                                           FontSize="11"
                                           TextColor="{StaticResource TextLightColor}"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>

                                <Label Text="Edit Profile"
                                       TextColor="{StaticResource LoginColor}"
                                       FontSize="12" FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       Margin="0,4,0,0">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.NavigateToEditCommand}"
                                            CommandParameter="{Binding Id}" />
                                    </Label.GestureRecognizers>
                                </Label>

                            </VerticalStackLayout>
                        </Border>

                        <!-- Current user card — teal border + green dot -->
                        <Border StrokeShape="RoundRectangle 16"
                                StrokeThickness="2"
                                Stroke="{StaticResource LoginColor}"
                                Padding="12"
                                BackgroundColor="#1A1A1A"
                                IsVisible="{Binding IsCurrentUser}">
                            <Border.Shadow>
                                <Shadow Brush="{StaticResource LoginColor}"
                                        Offset="0,2" Radius="10" Opacity="0.4" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="12" HorizontalOptions="Center" Padding="0,8">

                                <!-- Avatar + green dot -->
                                <Grid WidthRequest="54" HeightRequest="54" HorizontalOptions="Center">
                                    <Border WidthRequest="50" HeightRequest="50"
                                            StrokeShape="RoundRectangle 25" StrokeThickness="0"
                                            BackgroundColor="{Binding AvatarColor}"
                                            IsVisible="{Binding HasProfilePicture}">
                                        <Image Source="{Binding ProfilePicturePath}"
                                               Aspect="AspectFill"
                                               WidthRequest="50" HeightRequest="50" />
                                    </Border>
                                    <Border WidthRequest="50" HeightRequest="50"
                                            StrokeShape="RoundRectangle 25" StrokeThickness="0"
                                            BackgroundColor="{Binding AvatarColor}"
                                            IsVisible="{Binding HasProfilePicture, Converter={StaticResource InverseBoolConverter}}">
                                        <Label Text="{Binding Initials}"
                                               TextColor="{StaticResource WhiteColor}"
                                               FontSize="18" FontAttributes="Bold"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>

                                    <!-- Green dot -->
                                    <Border WidthRequest="14" HeightRequest="14"
                                            StrokeShape="RoundRectangle 7"
                                            StrokeThickness="2"
                                            Stroke="{StaticResource AppBackgroundColor}"
                                            BackgroundColor="{StaticResource SuccessColor}"
                                            HorizontalOptions="End"
                                            VerticalOptions="Start" />
                                </Grid>

                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding FullName}"
                                           FontAttributes="Bold" FontSize="14"
                                           TextColor="{StaticResource WhiteColor}"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding Role}"
                                           FontSize="11"
                                           TextColor="{StaticResource TextLightColor}"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center" />
                                </VerticalStackLayout>

                                <Label Text="Edit Profile"
                                       TextColor="{StaticResource LoginColor}"
                                       FontSize="12" FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       Margin="0,4,0,0">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.NavigateToEditCommand}"
                                            CommandParameter="{Binding Id}" />
                                    </Label.GestureRecognizers>
                                </Label>

                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <BoxView HeightRequest="24" Color="Transparent" />
            </CollectionView.Footer>

        </CollectionView>

    </Grid>
</ContentPage>