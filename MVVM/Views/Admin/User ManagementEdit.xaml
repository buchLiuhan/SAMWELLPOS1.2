<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SAMWELLPOS.MVVM.Views.Admin.User_ManagementEdit"
             Title="User_ManagementEdit"
             BackgroundColor="{StaticResource AppBackgroundColor}">

    <Grid RowDefinitions="Auto, *" Padding="24">

        <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Margin="0,0,0,24">
            <Label Text="Edit User Profile" Style="{StaticResource HeaderLabelStyle}" FontSize="24" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">

            <Border Style="{StaticResource CardBorderStyle}" HorizontalOptions="Fill" VerticalOptions="Start">
                <VerticalStackLayout Spacing="20">

                    <Grid HorizontalOptions="Center" Margin="0,10,0,20">

                        <Border x:Name="ProfileImageBorder"
                                WidthRequest="120" HeightRequest="120"
                                StrokeShape="RoundRectangle 60"
                                StrokeThickness="0"
                                BackgroundColor="{StaticResource LoginColor}">
                            <Label Text="JD" TextColor="{StaticResource WhiteColor}" FontSize="40" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer />
                            </Border.GestureRecognizers>
                        </Border>

                        <Border Margin="0,0,0,-8" VerticalOptions="End" HorizontalOptions="Center" Style="{StaticResource PillBorderStyle}" BackgroundColor="#D91c1c1c" Padding="12, 6">
                            <Label Text="Edit" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource WhiteColor}" HorizontalOptions="Center"/>
                        </Border>
                    </Grid>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="USERNAME" Style="{StaticResource InputLabelStyle}" />
                        <Border Style="{StaticResource InputContainerStyle}">
                            <Entry Text="John Doe" Style="{StaticResource InputEntryStyle}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="EMAIL ADDRESS" Style="{StaticResource InputLabelStyle}" />
                        <Border Style="{StaticResource InputContainerStyle}">
                            <Entry Text="admin@samwell.com" Keyboard="Email" Style="{StaticResource InputEntryStyle}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="SYSTEM ROLE" Style="{StaticResource InputLabelStyle}" />
                        <Border Style="{StaticResource InputContainerStyle}">
                            <Picker Title="Select a role" TextColor="{StaticResource WhiteColor}" TitleColor="#7A8B99" Margin="0,4" FontSize="15">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>Admin</x:String>
                                        <x:String>User / Cashier</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                                <Picker.SelectedIndex>0</Picker.SelectedIndex>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, Auto" Margin="4,10,4,0">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="Account Approved" FontAttributes="Bold" TextColor="{StaticResource WhiteColor}" FontSize="15" />
                            <Label Text="User can log into the POS system" TextColor="{StaticResource TextLightColor}" FontSize="12" />
                        </VerticalStackLayout>

                        <Switch Grid.Column="1" IsToggled="True" OnColor="{StaticResource LoginColor}" />
                    </Grid>

                    <Button Text="Save Changes" Style="{StaticResource PrimaryButtonStyle}" Margin="0,20,0,0" />
                    <Button Text="Delete User" Style="{StaticResource ErrorButtonStyle}" Margin="0,10,0,0" />

                    <Label Text="Cancel" TextColor="{StaticResource TextLightColor}" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,15,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer />
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>
            </Border>

        </ScrollView>
    </Grid>
</ContentPage>