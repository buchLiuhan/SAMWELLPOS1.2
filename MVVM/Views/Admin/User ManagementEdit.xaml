<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SAMWELLPOS.MVVM.Views.Admin.User_ManagementEdit"
             Title="Edit User Profile"
             BackgroundColor="{StaticResource AppBackgroundColor}">

    <Grid RowDefinitions="Auto, *" Padding="24">

        <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Margin="0,0,0,24">
            <Label Text="Edit User Profile" Style="{StaticResource HeaderLabelStyle}" FontSize="24" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <Border Style="{StaticResource CardBorderStyle}" HorizontalOptions="Fill" VerticalOptions="Start">
                <VerticalStackLayout Spacing="20">

                    <!-- Avatar -->
                    <Grid HorizontalOptions="Center" Margin="0,10,0,20">
                        <Border WidthRequest="120" HeightRequest="120"
                                StrokeShape="RoundRectangle 60" StrokeThickness="0"
                                BackgroundColor="{StaticResource LoginColor}"
                                IsVisible="{Binding HasProfilePicture}">
                            <Image Source="{Binding ProfilePicturePath}"
                                   Aspect="AspectFill"
                                   WidthRequest="120" HeightRequest="120" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PickPhotoCommand}" />
                            </Border.GestureRecognizers>
                        </Border>

                        <Border WidthRequest="120" HeightRequest="120"
                                StrokeShape="RoundRectangle 60" StrokeThickness="0"
                                BackgroundColor="{StaticResource LoginColor}"
                                IsVisible="{Binding HasProfilePicture, Converter={StaticResource InverseBoolConverter}}">
                            <Label Text="{Binding Initials}"
                                   TextColor="{StaticResource WhiteColor}"
                                   FontSize="40" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PickPhotoCommand}" />
                            </Border.GestureRecognizers>
                        </Border>

                        <Border Margin="0,0,0,-8" VerticalOptions="End" HorizontalOptions="Center"
                                Style="{StaticResource PillBorderStyle}"
                                BackgroundColor="#D91c1c1c" Padding="12,6">
                            <Label Text="Edit Photo" FontSize="11" FontAttributes="Bold"
                                   TextColor="{StaticResource WhiteColor}"
                                   HorizontalOptions="Center" />
                        </Border>
                    </Grid>

                    <!-- Full Name -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="FULL NAME" Style="{StaticResource InputLabelStyle}" />
                        <Border Style="{StaticResource InputContainerStyle}">
                            <Entry Style="{StaticResource InputEntryStyle}"
                                   Text="{Binding FullName}" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="EMAIL ADDRESS" Style="{StaticResource InputLabelStyle}" />
                        <Border Style="{StaticResource InputContainerStyle}">
                            <Entry Keyboard="Email"
                                   Style="{StaticResource InputEntryStyle}"
                                   Text="{Binding Email}" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Role -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="SYSTEM ROLE" Style="{StaticResource InputLabelStyle}" />
                        <Border Style="{StaticResource InputContainerStyle}">
                            <Picker Title="Select a role"
                                    TextColor="{StaticResource WhiteColor}"
                                    TitleColor="#7A8B99"
                                    Margin="0,4" FontSize="15"
                                    ItemsSource="{Binding Roles}"
                                    SelectedItem="{Binding SelectedRole}" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Approved Toggle -->
                    <Grid ColumnDefinitions="*, Auto" Margin="4,10,4,0">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="Account Approved" FontAttributes="Bold"
                                   TextColor="{StaticResource WhiteColor}" FontSize="15" />
                            <Label Text="User can log into the POS system"
                                   TextColor="{StaticResource TextLightColor}" FontSize="12" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsApproved}"
                                OnColor="{StaticResource LoginColor}" />
                    </Grid>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="#2A2A2C" Margin="0,8,0,8" />

                    <!-- Password Section -->
                    <Label Text="CHANGE PASSWORD" Style="{StaticResource InputLabelStyle}" />
                    <Label Text="Leave blank to keep the current password."
                           FontSize="11" TextColor="{StaticResource TextLightColor}"
                           Margin="4,0,0,0" />

                    <VerticalStackLayout Spacing="8">
                        <Label Text="NEW PASSWORD" Style="{StaticResource InputLabelStyle}" />
                        <Border Style="{StaticResource InputContainerStyle}">
                            <Entry Placeholder="••••••••"
                                   IsPassword="True"
                                   Style="{StaticResource InputEntryStyle}"
                                   Text="{Binding NewPassword}" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="CONFIRM NEW PASSWORD" Style="{StaticResource InputLabelStyle}" />
                        <Border Style="{StaticResource InputContainerStyle}">
                            <Entry Placeholder="••••••••"
                                   IsPassword="True"
                                   Style="{StaticResource InputEntryStyle}"
                                   Text="{Binding ConfirmNewPassword}" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Error -->
                    <Border BackgroundColor="{StaticResource MutedError2}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            Padding="14,10"
                            IsVisible="{Binding HasError}">
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="{StaticResource WhiteColor}"
                               FontSize="13" LineBreakMode="WordWrap" />
                    </Border>

                    <!-- Save -->
                    <Button Text="Save Changes"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SaveChangesCommand}"
                            Margin="0,20,0,0" />

                    <!-- Delete -->
                    <Button Text="Delete User"
                            Style="{StaticResource ErrorButtonStyle}"
                            Command="{Binding DeleteUserCommand}"
                            Margin="0,0,0,0" />

                    <!-- Cancel -->
                    <Label Text="Cancel"
                           TextColor="{StaticResource TextLightColor}"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           Margin="0,15,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CancelCommand}" />
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>